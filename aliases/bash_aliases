# Git aliases
alias ga='git add'
alias gb='git branch'
alias gba='git branch -a'
alias gbd='git branch -D'
alias gc='git commit'
alias gcs='git commit --signoff'
alias gcad='git commit -a --signoff'
alias gcam='git commit --amend --signoff'
alias gcout='git checkout'
alias gf='git fetch'
alias gfa='git fetch --all'
alias gfo='git fetch origin'
alias gfp='git fetch --prune'
alias gfpa='git fetch --all --prune'
alias gfu='git fetch upstream'
alias gl='git log'
alias gln='git log --name-only'
alias gs='git status'
alias gsi='git status --ignored'
alias gsu='git status -u'
alias gsui='git status -u --ignored'
alias gstash='git stash'
alias gd='git diff'
alias gdh='git diff HEAD'
alias gdhp='git diff HEAD^'
alias gdn='git diff --name-only'
alias gdnh='git diff --name-only HEAD'
alias gdnhp='git diff --name-only HEAD^'
alias gpull='git pull'
alias gpullr='git pull --rebase'
alias gpush='git push'
alias gpusho='git push --set-upstream origin HEAD'
alias gpushm='git push --set-upstream mauro HEAD'
alias gpushb='git push --set-upstream bechma HEAD'
alias gpushf='git push --force-with-lease'
alias gpushof='git push --force-with-lease --set-upstream origin HEAD'
alias gpushmf='git push --force-with-lease --set-upstream mauro HEAD'
alias gpushbf='git push --force-with-lease --set-upstream bechma HEAD'
alias greset='git reset'
alias greseth='git reset HEAD'
alias gresethp='git reset HEAD^'
alias grm='git rm'
alias grmf='git rm -f'
alias gr='git restore'
alias grs='git restore --staged'
alias gt='git tag'
alias gts='git tag --sort=creatordate | tail -n 24'

# Cargo aliases
alias cb='cargo fmt; cargo build'
alias cbr='cb --release'
alias cbe='cb --examples'
alias cbnd='cb --no-default-features'
alias cbn='cargo +nightly build'
alias cbench='cargo fmt; cargo bench'
alias cbenchn='cargo +nightly bench'
alias cc='cargo clean'
alias ccheck='cargo check'
alias cfix='cargo fix --lib --allow-dirty --allow-staged'
alias clip='cargo clippy --bin --tests -- -D warnings'
alias clipf='cargo clippy --bin --tests --fix --allow-dirty --allow-staged -- -D warnings'
alias clipt='cargo clippy --tests -- -D warnings'
alias clipa='cargo clippy --all-targets -- -D warnings'
alias clipaf='cargo clippy --all-targets --fix --allow-dirty --allow-staged --'
alias clipafd='cargo clippy --all-targets --fix --allow-dirty --allow-staged -- -D warnings'
alias clipau='cargo clippy --all-targets -- -D warnings -A unused'
alias clipn='cargo +nightly clippy -- -D warnings'
alias clipnf='cargo +nightly clippy --fix --allow-dirty --allow-staged -- -D warnings'
alias clipnt='cargo +nightly clippy --tests -- -D warnings'
alias clipntf='cargo +nightly clippy --tests --fix --allow-dirty --allow-staged -- -D warnings'
alias clipna='cargo +nightly clippy --all-targets -- -D warnings'
alias clipnaf='cargo +nightly clippy --all-targets --fix --allow-dirty --allow-staged -- -D warnings'
alias cf='cargo fmt --all'
alias cfc='cargo fmt --all -- --check'
alias ct='cargo test'
alias ctfv='cargo test --features full-validation'
alias ctl='cargo test --lib'
alias ctnd='cargo test --no-default-features'
alias ctlnd='cargo test --lib --no-default-features'
alias cta='cargo test --all-features'
alias ctr='cargo test --release'
alias ctnc='cargo test -- --nocapture'
alias cup='cargo update'
alias cti='cargo test --test integration'
alias ctinc='cargo test --test integration -- --nocapture'
alias ctlfv='cargo test --lib --features full-validation'
alias ctlfvnc='cargo test --lib --features full-validation -- --nocapture'
alias cr='cargo run --'
alias crb='cargo run --bin'
alias crs='cargo run-script'

# Specific aliases
alias eq='bc -l <<<'
alias make='make -j$(($(sysctl -n hw.ncpu) - 2))'
alias pe='ps -ef'
alias xnargs="tr '\n' '\0' | xargs -0 -n1"

# ls aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'

# gnu-locate for Mac
alias updatedb='gupdatedb --localpaths="$HOME /usr/local /Applications"'
alias locate='glocate'

alias my_ip='dig +short myip.opendns.com @resolver1.opendns.com'

alias killbrowser='ps aux -r | egrep "(chrom|firefox)" | head -1 | awk "{print \$2}" | xargs kill 2>/dev/null'

alias ipython='ipython --no-confirm-exit'
alias ipython3='ipython3 --no-confirm-exit'

alias unhash='hash -r'

# Claude
alias clauder='claude --resume'
alias claude4.6='claude --model claude-opus-4-6'
alias clauder4.6='claude --resume --model claude-opus-4-6'
alias claudeh='claude --model claude-haiku-4-5'
alias clauderh='claude --resume --model claude-haiku-4-5'
